# Public frontend port on the target machine.
FRONTEND_PORT=18765

# Pipeline mode.
WEB_PROCESSOR_MODE=pipeline
WEB_PIPELINE_DEBUG=1
WEB_PIPELINE_CONCURRENCY=1
WEB_PROGRESS_POLL_INTERVAL_SEC=0.5

# Crop tuning. Increase slightly if the number line is cut off.
ANCHOR_EXPAND_RATIO=3.6

# Upload limits.
WEB_MAX_UPLOAD_FILES=50
WEB_MAX_UPLOAD_SIZE_MB=25
WEB_ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,webp,bmp

# Model paths and OCR settings.
YOLO_MODEL_PATH=models/yolo26n.pt
OCR_MODE=qwen
MODEL_NAME=qwen2.5vl:3b
MODEL_BASE_URL=http://ollama:11434

# GPU pipeline settings. docker-compose.yml is GPU-first.
PIPELINE_DEVICE=cuda
PIPELINE_REQUIRE_GPU=1
YOLO_DEVICE=0
EASYOCR_GPU=1

# Optional image/version overrides.
OLLAMA_IMAGE_TAG=latest
TORCH_INDEX_URL=https://download.pytorch.org/whl/cu121

# Persistent Docker volume names.
OLLAMA_VOLUME=gradebook_ollama_data
EASYOCR_VOLUME=gradebook_easyocr_data
GRADEBOOK_NETWORK=gradebook_network
