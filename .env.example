# Deployment profile: gpu | cpu
DEPLOY_PROFILE=gpu

# Only frontend is published on the host. Backend and Ollama stay inside Docker network.
# Change this if the port is already busy on the target machine.
FRONTEND_PORT=18765

# Runtime mode
WEB_PROCESSOR_MODE=pipeline
WEB_PIPELINE_DEBUG=1
WEB_PIPELINE_CONCURRENCY=1
WEB_JOBS_DIR=data/web_jobs

# Upload limits
WEB_MAX_UPLOAD_FILES=50
WEB_MAX_UPLOAD_SIZE_MB=25
WEB_ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,webp,bmp

# Models
# YOLO model is not stored in git. Put the file here before deploy:
#   models/yolo26n.pt
YOLO_MODEL_PATH=models/yolo26n.pt
OCR_MODE=qwen
MODEL_NAME=qwen2.5vl:3b
MODEL_BASE_URL=http://ollama:11434

# Docker names
GRADEBOOK_NETWORK=gradebook_network
OLLAMA_VOLUME=gradebook_ollama_data
OLLAMA_IMAGE_TAG=latest

# Jobs cleanup helper
CLEANUP_JOBS_DAYS=14
